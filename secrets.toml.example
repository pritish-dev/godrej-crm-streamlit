# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE REVIEWS CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
#
# CHOOSE ONE of these two options:
#
# ┌─ OPTION 1: Google Places API (RECOMMENDED) ─────────────────────────────┐
# │                                                                           │
# │ Best for: Most showrooms (free, simple, no allow-listing needed)        │
# │                                                                           │
# │ How to get credentials:                                                  │
# │ 1. Google Cloud Console → Enable "Places API"                           │
# │ 2. Create an API Key (restrict to HTTP referrers + Places API)          │
# │ 3. Google Maps → Find your business → Copy Place ID from URL            │
# │                                                                           │
# │ Setup: Just uncomment the two lines below and add YOUR values           │
# │                                                                           │
# │ See GOOGLE_REVIEWS_SETUP.md for detailed instructions                   │
# │                                                                           │
# └───────────────────────────────────────────────────────────────────────────┘
#
# GOOGLE_PLACES_API_KEY = "AIzaSyD_YOUR_API_KEY_HERE"
# GOOGLE_PLACE_ID = "ChIJ_YOUR_PLACE_ID_HERE"
#
#
# ┌─ OPTION 2: Google My Business v4 API (Full History) ────────────────────┐
# │                                                                           │
# │ Best for: Large showrooms that want complete review history             │
# │                                                                           │
# │ Requires: Google's allow-listing (request via Google My Business)       │
# │ Wait time: 1-2 weeks for approval                                       │
# │                                                                           │
# │ After allow-listing, run: python generate_gmb_refresh_token.py          │
# │                                                                           │
# │ See GOOGLE_REVIEWS_SETUP.md for detailed instructions                   │
# │                                                                           │
# └───────────────────────────────────────────────────────────────────────────┘
#
# GMB_CLIENT_ID = "YOUR_CLIENT_ID.apps.googleusercontent.com"
# GMB_CLIENT_SECRET = "YOUR_CLIENT_SECRET"
# GMB_REFRESH_TOKEN = "1//0YOUR_REFRESH_TOKEN_HERE"
# GMB_ACCOUNT_ID = "123456789"          # Find in GMB Settings
# GMB_LOCATION_ID = "987654321"         # Find in GMB Settings
#
# ─────────────────────────────────────────────────────────────────────────────

